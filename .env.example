# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Set to 0/false/off only when another deployment step applies migrations.
# By default, `npm run build` runs safe pending migrations automatically.
# DRIZZLE_AUTO_MIGRATE=1

# ---------------------------------------------------------------------------
# Content publishing scheduler
# ---------------------------------------------------------------------------
# Required for scheduled publish/unpublish. Vercel Cron automatically sends
# CRON_SECRET as an Authorization: Bearer header when it invokes the route.
# Local/self-hosted callers should send the same value as Authorization: Bearer
# or as x-cron-secret. Keep this secret in .env / hosting env vars only.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Optional separate secret accepted by the publishing cron endpoint. Useful if
# self-hosted callers should not share Vercel's CRON_SECRET.
# CONTENT_PUBLISHING_CRON_SECRET=

# Optional full scheduler endpoint URL used by these commands:
#   npm run content:scheduler:run
#   npm run content:scheduler:dev
#   npm run content:scheduler:worker
#
# Dev default:
#   http://localhost:${PORT:-3000}/api/cron/content-publishing
#
# Self-hosted example:
#   CONTENT_PUBLISHING_CRON_URL=https://your-domain.com/api/cron/content-publishing
# CONTENT_PUBLISHING_CRON_URL=

# Continuous local/self-hosted worker settings. Vercel uses vercel.json instead.
# `run` executes once; `dev` and `worker` repeat every interval.
CONTENT_PUBLISHING_SCHEDULER_INTERVAL_SECONDS=60
# CONTENT_PUBLISHING_SCHEDULER_ENABLED=true
# CONTENT_PUBLISHING_SCHEDULER_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Clerk auth
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
# Selects the storage backend used by the File Manager, Gallery Manager,
# the global-settings logo upload, and form-builder file fields.
#
#   local        -> writes to the local filesystem (default; self-hosted).
#   vercel-blob  -> uses Vercel Blob (recommended on Vercel).
#
# Leave unset to auto-detect: when running on Vercel (VERCEL=1) with a
# BLOB_READ_WRITE_TOKEN present, vercel-blob is used; otherwise local.
STORAGE_PROVIDER=local

# --- local provider --------------------------------------------------------
# Where uploaded files are stored on disk. Defaults to ./storage/uploads.
# Self-hosted only — has no effect on Vercel.
UPLOADS_DIR=./storage/uploads

# --- vercel-blob provider --------------------------------------------------
# Required when STORAGE_PROVIDER=vercel-blob. Created automatically when you
# attach a Blob store to a Vercel project (Vercel injects this env var into
# every deployment). For local development pull it with `vercel env pull`.
# BLOB_READ_WRITE_TOKEN=

# Vercel serverless functions cap request bodies at ~4.5 MB by default.
# Set this when Fluid Compute is enabled to lift the cap to ~200 MB:
# VERCEL_FLUID_COMPUTE=1
#
# Or override the cap explicitly (in bytes):
# VERCEL_BLOB_MAX_UPLOAD_BYTES=104857600

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
EMAIL_FROM="CMS <noreply@example.com>"
EMAIL_PROVIDER=resend
RESEND_API_KEY=

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=true

# ---------------------------------------------------------------------------
# Cloudflare Turnstile (blog comments + public forms)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# >=32 char random string used to SHA-256 hash visitor IPs for rate limiting.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Server-only, 32-byte base64url key used to encrypt CMS installation private keys.
# Never share it with clients or reuse a production value in test.
NR_ADDON_INSTALLATION_ENCRYPTION_KEY=
# JSON kid -> central vendor Ed25519 PEM public key map, staged/pinned before enabling V1.
NR_VENDOR_ENTITLEMENT_PUBLIC_KEYS_JSON={}
WEBSHOP_DEPLOYMENT_MODE=
LICENSE_SERVER_DEPLOYMENT_MODE=

# Required by `npm run db:migrate:test` and `npm run test:db`. This must be a
# dedicated PostgreSQL database whose name contains a standalone `test` marker;
# it is never read by normal runtime migrations.
# TEST_DATABASE_URL="postgresql://user:password@localhost:5432/nr_cms_test"

# Builds are DB-neutral. Migrations are a separate, explicit operator step.
# `DRIZZLE_AUTO_MIGRATE` only controls `npm run db:migrate`; keep it disabled
# outside a separately approved migration window.
# DRIZZLE_AUTO_MIGRATE=0

# ---------------------------------------------------------------------------
# Content publishing scheduler
# ---------------------------------------------------------------------------
# Required for scheduled publish/unpublish. Vercel Cron automatically sends
# CRON_SECRET as an Authorization: Bearer header when it invokes the route.
# Local/self-hosted callers should send the same value as Authorization: Bearer
# or as x-cron-secret. Keep this secret in .env / hosting env vars only.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Optional separate secret accepted by the publishing cron endpoint. Useful if
# self-hosted callers should not share Vercel's CRON_SECRET.
# CONTENT_PUBLISHING_CRON_SECRET=

# Optional full scheduler endpoint URL used by these commands:
#   npm run content:scheduler:run
#   npm run content:scheduler:dev
#   npm run content:scheduler:worker
#
# Dev default:
#   http://localhost:${PORT:-3000}/api/cron/content-publishing
#
# Self-hosted example:
#   CONTENT_PUBLISHING_CRON_URL=https://your-domain.com/api/cron/content-publishing
# CONTENT_PUBLISHING_CRON_URL=

# Continuous local/self-hosted worker settings. Vercel uses vercel.json instead.
# `run` executes once; `dev` and `worker` repeat every interval.
CONTENT_PUBLISHING_SCHEDULER_INTERVAL_SECONDS=60
# CONTENT_PUBLISHING_SCHEDULER_ENABLED=true
# CONTENT_PUBLISHING_SCHEDULER_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Clerk auth
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
# Selects the storage backend used by the File Manager, Gallery Manager,
# the global-settings logo upload, and form-builder file fields.
#
#   local        -> writes to the local filesystem (default; self-hosted).
#   vercel-blob  -> uses Vercel Blob (recommended on Vercel).
#
# Leave unset to auto-detect: when running on Vercel (VERCEL=1) with a
# BLOB_READ_WRITE_TOKEN present, vercel-blob is used; otherwise local.
STORAGE_PROVIDER=local

# --- local provider --------------------------------------------------------
# Where uploaded files are stored on disk. Defaults to ./storage/uploads.
# Self-hosted only — has no effect on Vercel.
UPLOADS_DIR=./storage/uploads

# --- vercel-blob provider --------------------------------------------------
# Required when STORAGE_PROVIDER=vercel-blob. Created automatically when you
# attach a Blob store to a Vercel project (Vercel injects this env var into
# every deployment). For local development pull it with `vercel env pull`.
# BLOB_READ_WRITE_TOKEN=

# Vercel serverless functions cap request bodies at ~4.5 MB by default.
# Set this when Fluid Compute is enabled to lift the cap to ~200 MB:
# VERCEL_FLUID_COMPUTE=1
#
# Or override the cap explicitly (in bytes):
# VERCEL_BLOB_MAX_UPLOAD_BYTES=104857600

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
EMAIL_FROM="CMS <noreply@example.com>"
EMAIL_PROVIDER=resend
RESEND_API_KEY=

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=true

# ---------------------------------------------------------------------------
# Cloudflare Turnstile (blog comments + public forms)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# >=32 char random string used to SHA-256 hash visitor IPs for rate limiting.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=

# ---------------------------------------------------------------------------
# Paid Webshop add-on
# ---------------------------------------------------------------------------
# Master switch. Set to 0/false/off to fail closed: dashboard activation,
# storefront rendering, checkout, and API routes become unavailable.
WEBSHOP_ENABLED=true

# Night Raven P0/P1 remediation rollout flags. Server-only; all default false.
WEBSHOP_PAYMENT_STATE_V2=false
WEBSHOP_LICENSE_OUTBOX_V2=false
VENDOR_LICENSE_API_V2=false
VENDOR_SIGNED_ENTITLEMENTS_V1=false
ADDON_INSTALL_RECONCILIATION_V1=false
ADDON_SDK_V1=false

# Addon package selection is build-time allowlisted in addons.registry.json.
# Runtime environment values cannot select a module or filesystem path.

# Launch controls. Keep storefront hidden until launch, or keep the catalog
# visible while disabling coupon redemption and checkout.
WEBSHOP_STOREFRONT_ENABLED=true
WEBSHOP_CHECKOUT_ENABLED=true

# Activation and install controls. Webshop activation is supported on Vercel,
# other managed hosts, and self-hosted deployments. Set a stable self-hosted
# site ID when the public URL can change between rebuilds or environments.
WEBSHOP_INSTALL_MODE=managed_redeploy
# Package selection is generated at build time from addons.registry.json.
WEBSHOP_LICENSE_API_URL=
WEBSHOP_LICENSE_KEY=
WEBSHOP_LICENSE_PUBLIC_KEY=
WEBSHOP_PACKAGE_TOKEN=
WEBSHOP_REDEPLOY_WEBHOOK_URL=
# WEBSHOP_SELF_HOSTED_SITE_ID=your-domain-or-stable-install-id

# 32-byte base64url, base64, or hex key used to encrypt external Night Raven
# License Server shared secrets stored by the webshop.
WEBSHOP_LICENSE_SERVER_SECRET_KEY=
WEBSHOP_BUY_URL=https://www.nrcms.com/webshop
WEBSHOP_BUY_LINK_SECRET=
WEBSHOP_LICENSE_ISSUE_CRON_SECRET=

# Payment providers must start in test mode. Switch to live only after provider
# webhooks, secrets, fulfillment, refunds, and order emails are verified.
WEBSHOP_PAYMENTS_MODE=test
# Optional public origin used for externally hosted payment checkouts and return
# URLs. Set this to your ngrok HTTPS origin during local Paddle/PayPal testing.
# WEBSHOP_PUBLIC_BASE_URL=https://your-ngrok-domain.ngrok-free.dev
WEBSHOP_STRIPE_SECRET_KEY=
WEBSHOP_STRIPE_WEBHOOK_SECRET=
WEBSHOP_PAYPAL_CLIENT_ID=
WEBSHOP_PAYPAL_CLIENT_SECRET=
WEBSHOP_PAYPAL_WEBHOOK_ID=
# Optional override. Defaults to sandbox when WEBSHOP_PAYMENTS_MODE=test and
# live when WEBSHOP_PAYMENTS_MODE=live.
# WEBSHOP_PAYPAL_API_BASE_URL=
WEBSHOP_PADDLE_API_KEY=
WEBSHOP_PADDLE_CLIENT_TOKEN=
WEBSHOP_PADDLE_WEBHOOK_SECRET=
# Optional override. Defaults to sandbox when WEBSHOP_PAYMENTS_MODE=test and
# live when WEBSHOP_PAYMENTS_MODE=live. Configure Paddle webhooks at
# /api/webhooks/paddle.
# WEBSHOP_PADDLE_API_BASE_URL=
WEBSHOP_BANK_REDIRECT_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Paid License Server add-on
# ---------------------------------------------------------------------------
# This is the client-owned embedded License Server addon. It is activated by
# your master license server and then issues licenses for products the client
# sells through their CMS/webshop.
LICENSE_SERVER_ENABLED=true
LICENSE_SERVER_INSTALL_MODE=managed_redeploy
# Package selection is generated at build time from addons.registry.json.
LICENSE_SERVER_LICENSE_API_URL=
LICENSE_SERVER_LICENSE_KEY=
LICENSE_SERVER_PACKAGE_TOKEN=
LICENSE_SERVER_REDEPLOY_WEBHOOK_URL=
# LICENSE_SERVER_SELF_HOSTED_SITE_ID=your-domain-or-stable-install-id
LICENSE_SERVER_BUY_URL=https://www.nrcms.com/license-server
LICENSE_SERVER_BUY_LINK_SECRET=

# 32-byte base64url, base64, or hex key used by the embedded License Server
# addon to encrypt its API client shared secrets.
LICENSE_SERVER_SECRET_KEY=

# Digital download tokens and audit events never store raw IPs.
WEBSHOP_CART_TOKEN_SALT=
WEBSHOP_DOWNLOAD_TOKEN_SECRET=
WEBSHOP_DOWNLOAD_EVENT_HASH_SECRET=
